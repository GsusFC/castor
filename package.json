{
  "name": "castor",
  "version": "0.1.0",
  "private": true,
  "description": "Farcaster scheduler for studio accounts",
  "scripts": {
    "dev": "next dev --turbopack -p 3001",
    "dev:clean": "rm -f .next/dev/lock && next dev --turbopack -p 3001",
    "healthcheck": "node scripts/healthcheck.mjs",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui --open",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "ci:smoke": "node scripts/ci/smoke-check.mjs",
    "ci:rollback": "node scripts/ci/netlify-auto-rollback.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@farcaster/auth-client": "^0.7.1",
    "@farcaster/auth-kit": "^0.8.2",
    "@google/generative-ai": "^0.24.1",
    "@libsql/client": "^0.17.3",
    "@neynar/nodejs-sdk": "^3.173.0",
    "@noble/ed25519": "^3.1.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.100.10",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vitalets/google-translate-api": "^9.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "hls.js": "^1.6.16",
    "jose": "^6.2.3",
    "lucide-react": "^1.14.0",
    "nanoid": "^5.1.11",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.0",
    "react-dom": "^19.2.6",
    "react-intersection-observer": "^10.0.3",
    "react-tweet": "^3.3.0",
    "react-virtuoso": "^4.18.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "viem": "^2.48.11",
    "web-vitals": "^5.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@netlify/functions": "^5.2.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-config-next": "^16.2.6",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.3.0",
    "typescript": "6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.6"
  },
  "optionalDependencies": {
    "@libsql/linux-x64-gnu": "^0.5.10",
    "@libsql/linux-x64-musl": "^0.5.10"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
